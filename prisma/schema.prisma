generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                     @id @default(cuid())
  email               String                     @unique
  displayName         String
  role                UserRole                   @default(COOP_ADMIN)
  cooperativeId       String?                    @unique
  passwordHash        String?
  isActive            Boolean                    @default(true)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  cooperative         Cooperative?               @relation("CooperativeAdmin", fields: [cooperativeId], references: [id], onDelete: SetNull)
  createdCooperatives Cooperative[]              @relation("CooperativeCreatedBy")
  updatedCooperatives Cooperative[]              @relation("CooperativeUpdatedBy")
  requestedChanges    CooperativeChangeRequest[] @relation("RequestedBy")
  reviewedChanges     CooperativeChangeRequest[] @relation("ReviewedBy")
  createdBanners      HomeBanner[]               @relation("BannerCreatedBy")
  updatedBanners      HomeBanner[]               @relation("BannerUpdatedBy")
  blogPosts           BlogPost[]                 @relation("PostAuthor")
  createdEvents       Event[]                    @relation("EventCreatedBy")
  createdTestimonials Testimonial[]              @relation("TestimonialCreatedBy")
}

model Municipality {
  code         String        @id
  name         String        @unique
  cooperatives Cooperative[]
  branches     CooperativeBranch[]
}

model Cooperative {
  id               String                     @id @default(cuid())
  name             String
  slug             String                     @unique
  municipalityCode String
  foundedYear      Int?
  logoUrl          String?
  slogan           String?
  descriptionText  String?
  descriptionRich  Json?
  cooperativeTypes CooperativeType[]          @default([])
  tags             String[]                   @default([])
  status           CooperativeStatus          @default(DRAFT)
  reviewStatus     ReviewStatus               @default(PENDING)
  publishedAt      DateTime?
  createdById      String?
  updatedById      String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  municipality     Municipality               @relation(fields: [municipalityCode], references: [code], onDelete: Restrict)
  adminUser        User?                      @relation("CooperativeAdmin")
  createdBy        User?                      @relation("CooperativeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy        User?                      @relation("CooperativeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  services         CooperativeService[]
  branches         CooperativeBranch[]
  contacts         ContactPoint[]
  socialLinks      SocialLink[]
  gallery          GalleryImage[]
  changeRequests   CooperativeChangeRequest[]

  @@index([name])
  @@index([municipalityCode])
  @@index([status])
  @@index([cooperativeTypes], type: Gin)
  @@index([tags], type: Gin)
}

model CooperativeService {
  id            String      @id @default(cuid())
  cooperativeId String
  title         String
  description   String?
  sortOrder     Int         @default(0)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)

  @@index([cooperativeId, sortOrder])
}

model CooperativeBranch {
  id               String       @id @default(cuid())
  cooperativeId    String
  municipalityCode String
  label            String?
  address          String
  sortOrder        Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  cooperative      Cooperative  @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  municipality     Municipality @relation(fields: [municipalityCode], references: [code], onDelete: Restrict)

  @@index([cooperativeId, sortOrder])
  @@index([municipalityCode])
}

model ContactPoint {
  id            String      @id @default(cuid())
  cooperativeId String
  type          ContactType
  label         String?
  value         String
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)

  @@index([cooperativeId, sortOrder])
}

model SocialLink {
  id            String         @id @default(cuid())
  cooperativeId String
  platform      SocialPlatform
  url           String
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cooperative   Cooperative    @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)

  @@index([cooperativeId, sortOrder])
}

model GalleryImage {
  id            String      @id @default(cuid())
  cooperativeId String
  imageUrl      String
  altText       String?
  sortOrder     Int         @default(0)
  isPrimary     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)

  @@index([cooperativeId, sortOrder])
}

model HomeBanner {
  id          String     @id @default(cuid())
  slot        BannerSlot
  title       String
  imageUrl    String
  targetUrl   String?
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  activeFrom  DateTime?
  activeUntil DateTime?
  createdById String?
  updatedById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdBy   User?      @relation("BannerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?      @relation("BannerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([slot, isActive])
  @@index([slot, sortOrder])
}

model CooperativeChangeRequest {
  id            String              @id @default(cuid())
  cooperativeId String
  requestedById String
  reviewedById  String?
  severity      ChangeSeverity
  status        ChangeRequestStatus @default(PENDING)
  payload       Json
  notes         String?
  reviewedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  cooperative   Cooperative         @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  requestedBy   User                @relation("RequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  reviewedBy    User?               @relation("ReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([cooperativeId, status])
  @@index([status, severity])
}

enum UserRole {
  PLATFORM_ADMIN
  COOP_ADMIN
}

enum CooperativeStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

enum CooperativeType {
  AHORRO_CREDITO
  MOVIMIENTO_COOPERATIVO
  TIPOS_DIVERSOS
  TRABAJO_ASOCIADO
  CONSUMIDORES_USUARIOS
  VIVIENDA
  ENERGIA
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContactType {
  PHONE
  EMAIL
  WEBSITE
  WHATSAPP
  ADDRESS
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  X
  LINKEDIN
  YOUTUBE
  TIKTOK
  OTHER
}

enum BannerSlot {
  HERO
  SIDEBAR_TOP
  SIDEBAR_BOTTOM
}

enum ChangeSeverity {
  MINOR
  MAJOR
}

enum ChangeRequestStatus {
  PENDING
  AUTO_PUBLISHED
  APPROVED
  REJECTED
}

// ─── Blog ────────────────────────────────────────────────────────────────────

model BlogCategory {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now())
  posts     BlogPost[]

  @@index([slug])
}

model BlogPost {
  id             String       @id @default(cuid())
  title          String
  slug           String       @unique
  excerpt        String?
  bodyHtml       String?
  bodyText       String?
  coverImageUrl  String?
  status         PostStatus   @default(DRAFT)
  categoryId     String
  authorId       String?
  publishedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  category       BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  author         User?        @relation("PostAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([slug])
}

// ─── Eventos ─────────────────────────────────────────────────────────────────

model Event {
  id              String    @id @default(cuid())
  title           String
  location        String
  descriptionHtml String?
  descriptionText String?
  coverImageUrl   String?
  startsAt        DateTime
  endsAt          DateTime?
  infoUrl         String?
  isPublished     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdById     String?
  createdBy       User?     @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([startsAt, isPublished])
}

// ─── Testimonios ─────────────────────────────────────────────────────────────

model Testimonial {
  id                  String    @id @default(cuid())
  authorName          String
  authorRole          String?
  authorOrganization  String?
  avatarUrl           String?
  body                String
  isPublished         Boolean   @default(false)
  sortOrder           Int       @default(0)
  createdAt           DateTime  @default(now())
  createdById         String?
  createdBy           User?     @relation("TestimonialCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isPublished, sortOrder])
}

model PlatformSettings {
  id                   Int      @id @default(1)
  comingSoonEnabled    Boolean  @default(false)
  comingSoonMessage    String   @default("Proximamente estaremos al aire.")
  comingSoonLaunchAt   DateTime?
  homeShowEvents       Boolean  @default(true)
  homeShowTestimonials Boolean  @default(true)
  homeShowBlog         Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ─── Enums (Blog) ─────────────────────────────────────────────────────────────

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}